{
  "name": "medical-ai-backend",
  "version": "1.0.0",
  "description": "Secure healthcare workflow prototype with Gemini structured extraction and clinician review",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:production": "node server.js",
    "dev": "node --watch server.js",
    "db:create": "node scripts/create-database.js",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "db:init": "npm run db:create && npm run db:setup",
    "test": "node --test services/__tests__/*.test.js"
  },
  "keywords": [
    "medical",
    "ai",
    "chatbot",
    "healthcare"
  ],
  "author": "Medical AI Team",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^2.13.0",
    "axios": "^1.18.1",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "pg": "^8.11.3",
    "python-shell": "^5.0.0"
  }
}
